# betting-win-surebet local operator template.
# Copy to .env only on a private machine. Do not commit .env.

# Runtime note: root run-* controllers inherit the active parent-shell Node runtime.
# Activate Node 20 before long controller runs:
# . "$HOME/.nvm/nvm.sh" && nvm use 20

# Git helper settings. GITHUB_TOKEN is optional and must never be pasted into chat/logs.
# update_git.sh reads GITHUB_TOKEN from environment first, then .env.
# GITHUB_TOKEN=ghp_xxx

# Artifact pull helper settings. The remote repo path must point to betting-win-surebet.
# pull_artifacts_and_zip_codebase.sh reads these from environment first, then .env.
# SSH_HOST=example.server
# SSH_USER=dev
# SSH_PASSWORD=replace_me
REMOTE_REPO=/home/dev/app_testing/betting-win-surebet
# Optional override when the server artifact is not at $REMOTE_REPO/artifacts.zip.
# REMOTE_ARTIFACT=/home/dev/app_testing/betting-win-surebet/artifacts.zip

# Telegram final-run notifications. Optional. The shared helper reads env first, then .env.
# TELEGRAM_NOTIFY=1
# TELEGRAM_BOT_TOKEN=replace_me
# TELEGRAM_CHAT_ID=replace_me
# TELEGRAM_NOTIFY_DRY_RUN=1

# Private paper-mode pinned bundle controls.
# Current safe operation is private fixture smoke, plus repo-local pinned bundle smoke
# only after Federico provides a pinned betting-win export bundle. The paper
# controller shell-quotes this path and validates SUREBET_REQUIRE_PINNED_BUNDLE
# as strict 0 or 1.
# SUREBET_PINNED_BUNDLE=path/to/pinned-betting-win-export.json
SUREBET_REQUIRE_PINNED_BUNDLE=0

# Safety posture. These are documentation/validator signals only under the current private paper gate.
SUREBET_RUNTIME_MODE=paper
SUREBET_PROVIDER_CONNECTIONS=disabled
SUREBET_EXECUTION_ENABLED=false


# Paper autopilot defaults
# The autopilot is no-service/private-paper only. It supervises paper evaluation and bounded implementation handoffs.
# SUREBET_REQUIRE_PINNED_BUNDLE accepts only 0 or 1.
SUREBET_REQUIRE_PINNED_BUNDLE=0
# SUREBET_PINNED_BUNDLE=tests/fixtures/private-paper-mode-smoke/accepted-local-bundle.json
