# betting-win-surebet local operator template.
# Copy to .env only on a private machine. Do not commit .env.

# Git helper settings. GITHUB_TOKEN is optional and must never be pasted into chat/logs.
# GITHUB_TOKEN=ghp_xxx

# Artifact pull helper settings. The remote repo path must point to betting-win-surebet.
# SSH_HOST=example.server
# SSH_USER=dev
# SSH_PASSWORD=replace_me
REMOTE_REPO=/home/dev/app_testing/betting-win-surebet

# Contract/export dependency placeholders.
# SURE-001 does not consume real exports yet.
# BETTING_WIN_CONTRACT_PACKAGE=@panella87/betting-win-contracts
# BETTING_WIN_CONTRACT_VERSION=0.0.0
# BETTING_WIN_EXPORT_BUNDLE=/absolute/path/to/read-only/export-bundle.json

# Safety posture. These are documentation/validator signals only in SURE-001.
SUREBET_RUNTIME_MODE=paper
SUREBET_PROVIDER_CONNECTIONS=disabled
SUREBET_EXECUTION_ENABLED=false
