# betting-win-surebet local operator template.
# Copy to .env only on a private machine. Do not commit .env.

# Root controllers inherit the active parent-shell runtime.
# . "$HOME/.nvm/nvm.sh" && nvm use 20

# GITHUB_TOKEN=ghp_xxx
# SSH_HOST=example.server
# SSH_USER=dev
# SSH_PASSWORD=replace_me
REMOTE_REPO=/home/dev/app_testing/betting-win-surebet
# REMOTE_ARTIFACT=/home/dev/app_testing/betting-win-surebet/artifacts.zip

# TELEGRAM_NOTIFY=1
# TELEGRAM_BOT_TOKEN=replace_me
# TELEGRAM_CHAT_ID=replace_me
# TELEGRAM_NOTIFY_DRY_RUN=1

# Required BWS implementation input. No default is allowed.
# The verifier reads committed HEAD only and never clones or modifies this checkout.
# BETTING_WIN_REPO_PATH=/home/dev/app_testing/betting-win

# Fixed read-only betting-win API runtime for continuous upstream convergence.
# There is no runtime transport selector and no file-export runtime fallback.
# BWS_UPSTREAM_LOCK_PATH=config/betting-win.upstream.lock.json
# BWS_UPSTREAM_API_CHECKPOINT_ID=checkpoint-api-001
# BWS_UPSTREAM_API_BASE_URL=http://127.0.0.1:3000
# BWS_UPSTREAM_API_CONTRACT_VERSION=1.0.0
# BWS_UPSTREAM_API_PAGE_SIZE=25
# BWS_UPSTREAM_API_MAX_PAGES_PER_RESOURCE=4
# BWS_UPSTREAM_API_RETRY_LIMIT=2
# BWS_UPSTREAM_API_RETRY_BACKOFF_MS=250
# BWS_UPSTREAM_API_TIMEOUT_MS=10000
# BWS_PRIVATE_PAPER_SCHEDULE_PATH=runtime/operator-inputs/bws.private-paper-schedule.json

# Transitional retained paper-controller input only.
# SUREBET_PINNED_BUNDLE=tests/fixtures/private-paper-mode-smoke/accepted-local-bundle.json
SUREBET_REQUIRE_PINNED_BUNDLE=0

# Supported root runtime wrappers enforce this closed policy in code.
# Keep these exact values for direct package/release tooling; do not change them.
SUREBET_RUNTIME_MODE=paper
SUREBET_PROVIDER_CONNECTIONS=disabled
SUREBET_EXECUTION_ENABLED=false

# Canonical local PostgreSQL URLs. Keep credentials private in .env.
# BWS-510 accepts DB_URL_TEST as the explicit disposable-test connection source
# when no SUREBET_TEST_* tuple is exported. Its role must already have CREATEDB.
# DB_URL=postgresql://betting_win:replace_me@127.0.0.1:5432/betting_win_surebet
# DB_URL_TEST=postgresql://betting_win:replace_me@127.0.0.1:5432/betting_win_surebet_test

# Local BWS service-runtime contract for BWS-500 and later loopback acceptance.
# BWS_API_PORT=4312
# BWS_WORKER_ID=worker-bws-local-001
# BWS_WORKER_QUEUE_NAME=private-paper
# BWS_WORKER_LEASE_DURATION_MS=30000

# Cockpit browser mode stays explicit and loopback-safe.
# VITE_BWS_COCKPIT_DATA_MODE=mock
# VITE_BWS_COCKPIT_API_BASE_URL=http://127.0.0.1:4312
