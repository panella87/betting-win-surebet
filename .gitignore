# Dependencies and builds
node_modules/
dist/
coverage/
.nyc_output/

# Local env and secrets
# .env may exist locally, but must stay ignored and must never be archived.
.env
.env.local
.env.*.local
!.env.example
*.pem
*.key
*.crt
*.p12

# Runtime output and autonomous artifacts
artifacts/*
!artifacts/.gitkeep
!artifacts/**/.gitkeep
output/
tmp/
.tmp/
.locks/
.codex_current_artifact_dir
autonomous-codebase.zip
autonomous-handoff.manifest.json
artifacts.zip

# Logs and transient files
*.log
*.stdout
*.stderr
*.stdout.txt
*.stderr.txt
*.stdout.log
*.stderr.log
*.tap
*.tap.log
*.tmp
*.swp
*.swo
.DS_Store

# Local archives
*.zip
*.tar
*.tar.gz
*.tgz

# Python cache
__pycache__/
*.pyc

# Historical accidental file from upstream reference repos
/true
