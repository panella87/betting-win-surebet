# Secrets
.env
.env.*
!.env.example
*.pem
*.key
*.secret
secrets.*

# Node / Python
node_modules/
dist/
build/
coverage/
.npm/
.pnpm-store/
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# OS / editors
.DS_Store
Thumbs.db
.vscode/*
!.vscode/extensions.json
.idea/

# Runtime / data
*.log
logs/
tmp/
.cache/
/data/raw/*
!/data/raw/.gitkeep
/data/external/*
!/data/external/.gitkeep
/data/processed/*
!/data/processed/.gitkeep

# Generated archives, except curated evidence captures
*.zip
*.tar
*.tar.gz
!research/captures/**/*.zip

# Expanded local captures
research/captures/sx/sx_*/
research/captures/azuro/*/
!research/captures/sx/*.zip
!research/captures/azuro/*.zip


# Historical stage-specific expanded capture patterns retained for validator compatibility
research/captures/sx/sx_stage13_ws_contract_capture_*/
research/captures/sx/sx_stage14_ws_retry_*/
research/captures/sx/sx_stage15_ws_token_shape_comprehensive_*/

# Upstream source archives/workspaces stay outside the repo
/vendor-upstream/
/upstream-sources/
/azuro-source-audit-work/
/sx-source-audit-work/

# Packaging metadata must not be copied into overlays
.git/
.github/
OVERLAY_MANIFEST.json
OVERLAY_README.md
VALIDATION_REPORT*.md
MANIFEST.json
# Polymarket source/capture workspaces stay outside tracked source
/polymarket-source-audit-work/
research/captures/polymarket/*/
!research/captures/polymarket/*.zip
