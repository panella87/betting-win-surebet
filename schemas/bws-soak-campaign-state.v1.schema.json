{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "bws.soak_campaign_state.v1.schema.json",
  "title": "BWS Soak Campaign State",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "campaignSemanticFingerprint",
    "completedCycleCount",
    "createdAt",
    "currentCheckpointSequence",
    "schema",
    "updatedAt"
  ],
  "properties": {
    "campaignSemanticFingerprint": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "completedCycleCount": {
      "type": "integer",
      "minimum": 0
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "currentCheckpointSequence": {
      "type": "integer",
      "minimum": 0
    },
    "lastCheckpointFile": {
      "type": "string",
      "minLength": 1
    },
    "lastCheckpointFingerprint": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "runtimeEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "elapsedWallClockMs",
        "lastObservedAt",
        "observationCount",
        "requiredDurationMs",
        "runner",
        "startedAt"
      ],
      "properties": {
        "completedAt": {
          "type": "string",
          "format": "date-time"
        },
        "elapsedWallClockMs": {
          "type": "integer",
          "minimum": 0
        },
        "lastObservedAt": {
          "type": "string",
          "format": "date-time"
        },
        "observationCount": {
          "type": "integer",
          "minimum": 0
        },
        "requiredDurationMs": {
          "type": "integer",
          "minimum": 1
        },
        "runner": {
          "const": "managed_runtime"
        },
        "startedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "schema": {
      "const": "bws.soak_campaign_state.v1"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
